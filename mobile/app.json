{
  "expo": {
    "name": "CoffeeDex",
    "slug": "coffeedex",
    "version": "1.0.0",
    "scheme": "coffeedex",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.lucasdev.coffeedex",
      "infoPlist": {
        "NSCameraUsageDescription": "CoffeeDex uses the camera when you upload or capture coffee memories.",
        "NSPhotoLibraryUsageDescription": "CoffeeDex lets you choose photos for coffee tasting notes."
      }
    },
    "android": {
      "package": "kr.lucasdev.coffeedex",
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CoffeeDex to access your camera to scan coffee beans."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ]
    ]
  }
}
